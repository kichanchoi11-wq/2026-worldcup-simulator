# football-data.org 실제 경기/순위 API 키입니다.
# 없으면 실제 API 새로고침만 제한되고, 내부 AI 예측은 빈 화면 없이 작동합니다.
FOOTBALL_DATA_API_KEY=

# 선택 사항: Gemini 기반 설명/요약 기능을 붙일 때 사용합니다.
# 현재 전체 대회 AI 예측은 이 키가 없어도 내부 규칙 모델로 실행됩니다.
GEMINI_API_KEY=

# 선택 사항: Vercel Cron route 보호용 토큰입니다.
# 설정하면 /api/cron/update-football-data 요청은 Authorization: Bearer 값 검사를 통과해야 합니다.
CRON_SECRET=
