# API-Football(API-SPORTS)을 메인 데이터 API로 사용합니다.
# 서버 API Route에서만 읽으며 브라우저 번들에는 노출하지 않습니다.
API_FOOTBALL_KEY=

# API-Football 무료 플랜 보호용 호출 제한입니다.
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_DAILY_SOFT_LIMIT=95
API_FOOTBALL_PREDICTION_DETAIL_FIXTURE_LIMIT=1

# 2026 월드컵 조회 기본값입니다. API-Football의 World Cup 리그 ID는 기본 1로 둡니다.
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# football-data.org는 보조/fallback API로만 사용합니다.
FOOTBALL_DATA_ORG_KEY=

# 기존 로컬 환경 호환용 이름입니다. 새 설정은 FOOTBALL_DATA_ORG_KEY를 권장합니다.
FOOTBALL_DATA_API_KEY=

# 선택 사항: AI 설명/예측 Provider입니다. 서버 Route에서만 읽습니다.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=15000
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_TIMEOUT_MS=15000
AI_MAX_PAYLOAD_BYTES=30000
PROVIDER_COOLDOWN_MINUTES=30

# 선택 사항: 최신 정보 검색 Provider입니다. 부상/카드/라인업/뉴스는 출처 기반 검색만 반영합니다.
TAVILY_API_KEY=
EXA_API_KEY=
LATEST_INFO_PROVIDER_PRIORITY=tavily,exa
LATEST_INFO_SEARCH_TIMEOUT_MS=12000
LATEST_INFO_CACHE_TTL_HOURS=6
LATEST_INFO_MATCH_LIMIT=4

# 관리자 검토 모드와 수동 새로고침 보호용 비밀번호입니다.
# 운영 배포에서는 Vercel 환경변수로 이전해서 관리하는 것을 권장합니다.
ADMIN_PASSWORD=091009

# 선택 사항: Vercel Cron route 보호용 토큰입니다.
# 설정하면 /api/cron/update-football-data 요청은 Authorization: Bearer 값 검사를 통과해야 합니다.
CRON_SECRET=
